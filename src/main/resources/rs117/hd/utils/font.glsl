bool fontSample(int charCode, vec2 uv)
{
    int c   = clamp(charCode - 32, 0, 95);
    int col = clamp(int(uv.x * 8.0), 0, 7);
    int row = clamp(int((1.0 - uv.y) * 8.0), 0, 7);

    int bits = FONT[c * 8 + row];
    return ((bits >> (7 - col)) & 1) != 0;
}